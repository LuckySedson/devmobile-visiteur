<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nom du visiteur"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etNom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex : Alice Martin"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre de jours"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etNombreJours"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex : 5"
            android:inputType="number"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tarif journalier (€)"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etTarifJournalier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex : 50.00"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"/>

        <!-- Tarif calculé -->
        <TextView
            android:id="@+id/tvTarifCalcule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tarif total : -- €"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:background="#E8F5E9"
            android:padding="12dp"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/btnSauvegarder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 Sauvegarder"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>